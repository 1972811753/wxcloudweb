{
  "name": "galaxy-reception",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "dev:bigscreen": "pnpm --filter bigscreen dev",
    "dev:mobile": "pnpm --filter mobile dev",
